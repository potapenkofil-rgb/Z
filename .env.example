# ─── Telegram Bot ─────────────────────────────────────────────────
BOT_TOKEN=your_bot_token_here

# ─── CryptoBot ────────────────────────────────────────────────────
CRYPTOBOT_TOKEN=your_cryptobot_token_here

# ─── Proxy ────────────────────────────────────────────────────────
# false = прокси отключён (зарубежный сервер)
# true  = включить SOCKS5, задай PROXY_HOST и PROXY_PORT
USE_PROXY=false
PROXY_HOST=127.0.0.1
PROXY_PORT=10808
